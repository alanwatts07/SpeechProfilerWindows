# Windows Speech Profiler Configuration

# Anthropic API Key for Claude Analysis
ANTHROPIC_API_KEY=your-api-key-here

# Whisper Settings
WHISPER_MODEL_SIZE=base  # tiny, base, small, medium, large
WHISPER_DEVICE=cpu  # cpu or cuda
WHISPER_LANGUAGE=en

# Speaker Identification
# Resemblyzer is used - no HuggingFace token needed!
SPEAKER_SIMILARITY_THRESHOLD=0.75
AUTO_REGISTER_SPEAKERS=true

# Claude Analysis Thresholds
CLAUDE_ANALYSIS_THRESHOLD=200  # Words before first analysis
CLAUDE_REANALYSIS_INTERVAL=200  # Words between re-analyses

# Logging
LOG_LEVEL=INFO
